---
import { Image } from "astro:assets";
import appIcon from "../assets/app-icon.png";

const APP_STORE_URL = "https://apps.apple.com/us/app/life-visor/id6759874795";
const PLAY_STORE_URL = "https://play.google.com/store/apps/details?id=com.devsign.lifevisorapp";
---

<header class="w-full px-5 sm:px-8 pt-6">
  <nav class="max-w-6xl mx-auto flex items-center justify-between">
    <a href="/" class="flex items-center gap-3">
      <Image src={appIcon} alt="Life Visor" width={36} height={36} class="rounded-lg shadow-sm" />
      <span class="text-lg sm:text-xl text-ink"><span class="font-bold">Life</span> Visor</span>
    </a>
    <div class="flex items-center gap-6">
      <a href="/#features" class="hidden sm:inline text-sm text-muted hover:text-ink transition-colors">Features</a>
      <a href="/#pro" class="hidden sm:inline text-sm text-muted hover:text-ink transition-colors">Pro</a>
      <a
        href="/#download"
        data-download
        data-ios={APP_STORE_URL}
        data-android={PLAY_STORE_URL}
        class="text-sm font-medium px-4 py-2 rounded-full bg-ink text-white hover:opacity-90 transition-opacity"
      >
        Download
      </a>
    </div>
  </nav>
</header>

<script>
  const link = document.querySelector<HTMLAnchorElement>("a[data-download]");
  if (link) {
    link.addEventListener("click", (e) => {
      const ua = navigator.userAgent;
      const isIOS =
        /iPad|iPhone|iPod/.test(ua) ||
        (ua.includes("Mac") && navigator.maxTouchPoints > 1);
      const isAndroid = /android/i.test(ua);

      const target = isIOS
        ? link.dataset.ios
        : isAndroid
          ? link.dataset.android
          : null;

      if (target) {
        e.preventDefault();
        window.location.href = target;
      }
      // else: fall through to default href (/#download → scroll to hero)
    });
  }
</script>
