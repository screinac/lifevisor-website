---
import { Image } from "astro:assets";
import appIcon from "../assets/app-icon.png";

const year = new Date().getFullYear();
---

<footer class="w-full px-5 sm:px-8 py-12 border-t border-line-soft">
  <div class="max-w-6xl mx-auto flex flex-col sm:flex-row items-start sm:items-center justify-between gap-6">
    <div class="flex items-center gap-3">
      <Image src={appIcon} alt="Life Visor" width={32} height={32} class="rounded-lg" />
      <span class="text-sm text-ink"><span class="font-bold">Life</span> Visor</span>
    </div>

    <div class="flex flex-wrap items-center gap-x-6 gap-y-2 text-sm text-muted">
      <a href="mailto:support@lifevisorapp.com" class="hover:text-ink transition-colors">Contact</a>
      <a href="/privacy" class="hover:text-ink transition-colors">Privacy</a>
      <span>© {year} Life Visor</span>
    </div>
  </div>
</footer>
