---
---

<section class="w-full px-5 sm:px-8 py-20 sm:py-28">
  <div class="max-w-3xl mx-auto fade-in">
    <div class="flex items-center gap-3 mb-8">
      <span class="block w-5 h-[2px] bg-muted-2"></span>
      <span class="eyebrow text-ink-soft">PRIVACY FIRST</span>
    </div>

    <h2 class="text-4xl sm:text-5xl font-bold text-ink leading-[1.1] tracking-tight mb-8">
      Your data is <span class="highlight-blue">yours</span>
    </h2>

    <p class="text-base sm:text-lg text-muted leading-relaxed mb-10">
      Life Visor is designed with respect for your privacy. Your information stays with you on your
      device. We don't sell it, we don't share it, we don't even have a server that could see it.
    </p>

    <div class="grid sm:grid-cols-3 gap-4">
      <div class="p-5 rounded-2xl bg-bg-card border border-line-soft">
        <div class="w-9 h-9 rounded-lg bg-accent-bg flex items-center justify-center mb-3">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#447858" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect x="4" y="11" width="16" height="10" rx="2"/><path d="M8 11V7a4 4 0 0 1 8 0v4"/>
          </svg>
        </div>
        <p class="text-sm font-semibold text-ink mb-1">Local-only</p>
        <p class="text-xs text-muted leading-relaxed">All data lives in your device's local database.</p>
      </div>

      <div class="p-5 rounded-2xl bg-bg-card border border-line-soft">
        <div class="w-9 h-9 rounded-lg bg-accent-bg flex items-center justify-center mb-3">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#447858" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="10"/><line x1="4.93" y1="4.93" x2="19.07" y2="19.07"/>
          </svg>
        </div>
        <p class="text-sm font-semibold text-ink mb-1">No tracking</p>
        <p class="text-xs text-muted leading-relaxed">No analytics SDKs, no ads, no behavioral tracking.</p>
      </div>

      <div class="p-5 rounded-2xl bg-bg-card border border-line-soft">
        <div class="w-9 h-9 rounded-lg bg-accent-bg flex items-center justify-center mb-3">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#447858" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 2L4 5v6c0 5 3.5 9.7 8 11 4.5-1.3 8-6 8-11V5l-8-3z"/>
          </svg>
        </div>
        <p class="text-sm font-semibold text-ink mb-1">No accounts</p>
        <p class="text-xs text-muted leading-relaxed">No sign-up. Open the app and start tracking.</p>
      </div>
    </div>

    <a href="/privacy" class="inline-flex items-center gap-2 mt-8 text-sm text-ink-soft hover:text-ink underline underline-offset-4 decoration-line">
      Read the full privacy policy
      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
        <line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/>
      </svg>
    </a>
  </div>
</section>
