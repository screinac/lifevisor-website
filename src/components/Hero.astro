---
import { Image } from "astro:assets";
import appstoreBadge from "../assets/badge-appstore.svg";
import playstoreBadge from "../assets/badge-playstore.svg";
import homeScreenshot from "../assets/screenshots/home.png";

const APP_STORE_URL = "https://apps.apple.com/us/app/life-visor/id6759874795";
const PLAY_STORE_URL =
  "https://play.google.com/store/apps/details?id=com.devsign.lifevisorapp";
---

<section
  id="download"
  class="w-full px-5 sm:px-8 pt-16 sm:pt-24 pb-16 sm:pb-24"
>
  <div
    class="max-w-6xl mx-auto grid lg:grid-cols-2 gap-12 lg:gap-16 items-center"
  >
    <div class="fade-in">
      <div class="flex items-center gap-3 mb-6">
        <span class="block w-5 h-[2px] bg-muted-2"></span>
        <span class="eyebrow text-ink-soft">TIME · INTENTION · CLARITY</span>
      </div>

      <h1
        class="text-5xl sm:text-6xl lg:text-7xl font-bold text-ink leading-[1.05] tracking-tight mb-6"
      >
        See where your<br />time
        <span class="highlight">really goes</span>
      </h1>

      <p class="text-base sm:text-lg text-muted leading-relaxed mb-10 max-w-lg">
        Life Visor helps you track activities, spot the patterns you've been
        missing, and start living with more clarity. No surveillance vibes —
        your data stays on your device. No subscriptions.
      </p>

      <div class="flex flex-wrap items-center gap-4">
        <a
          href={APP_STORE_URL}
          target="_blank"
          rel="noopener"
          class="transition-transform hover:scale-[1.03]"
        >
          <Image
            src={appstoreBadge}
            alt="Download on the App Store"
            height={52}
            class="h-[52px] w-auto"
          />
        </a>
        <a
          href={PLAY_STORE_URL}
          target="_blank"
          rel="noopener"
          class="transition-transform hover:scale-[1.03]"
        >
          <Image
            src={playstoreBadge}
            alt="Get it on Google Play"
            height={52}
            class="h-[52px] w-auto"
          />
        </a>
      </div>

      <div
        class="flex flex-wrap items-center gap-x-6 gap-y-2 mt-8 text-xs text-muted-2"
      >
        <span class="flex items-center gap-2">
          <span class="w-1.5 h-1.5 rounded-full bg-accent"></span>
          One-time payment for Pro
        </span>
        <span class="flex items-center gap-2">
          <span class="w-1.5 h-1.5 rounded-full bg-accent"></span>
          Local-only data
        </span>
        <span class="flex items-center gap-2">
          <span class="w-1.5 h-1.5 rounded-full bg-accent"></span>
          iOS & Android
        </span>
      </div>
    </div>

    <div class="fade-in flex justify-center lg:justify-end lg:pr-8 xl:pr-12">
      <div class="relative">
        <div class="absolute -inset-8 bg-accent-bg/40 rounded-[60px] blur-3xl">
        </div>
        <div
          class="relative w-[260px] sm:w-[300px] aspect-[9/19.5] rounded-[44px] border border-line bg-bg-card shadow-2xl overflow-hidden"
        >
          <Image
            src={homeScreenshot}
            alt="Life Visor home screen"
            class="w-full h-full object-cover"
          />
        </div>
      </div>
    </div>
  </div>
</section>
