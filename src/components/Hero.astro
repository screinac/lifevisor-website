---
import { Image } from "astro:assets";
import hero1 from "../assets/hero.png";
import bg1 from "../assets/hero-bg-1.png";
import bg2 from "../assets/hero-bg-2.png";
import badgeAppStore from "../assets/badge-appstore.svg?url";
import badgePlayStore from "../assets/badge-playstore.svg?url";

const APP_STORE_URL = "https://apps.apple.com/us/app/life-visor/id6759874795";
const PLAY_STORE_URL = "https://play.google.com/store/apps/details?id=com.devsign.lifevisorapp&pli=1";
---

<div>
	<main>
		<section>
			<Image
				src={bg1}
				class={"absolute top-35"}
				layout="constrained"
				width={350}
				alt="Background image color blue"
			/>

			<Image
				src={bg2}
				class={"absolute top-75 right-0"}
				layout="constrained"
				width={300}
				alt="Background image color blue"
			/>

			<div class="md:px-[5vw] md:pb-[5vh]">
				<div
					class="glass bg-white/10 pt-18 pb-15 border border-white/50 rounded-b-[50px] md:rounded-[80px] md:pt-22 md:pb-20 px-12 md:justify-between md:px-[6vw] justify-center flex flex-col md:flex-row"
				>
					<div class="md:shrink-0 md:w-1/2 lg:w-auto">
						<h2
							class="mb-10 lg:text-7xl md:text-5xl md:text-left text-white text-3xl font-bold tracking-wide max-w-lg text-center"
						>
							Be
							<span
								class="italic md:not-italic md:font-bold font-normal"
							>
								mindful</span
							>

							of your
							<br class="md:hidden" />
							<span
								class="font-normal tracking-[.65em] md:tracking-[.3em]"
							>
								time
							</span>
						</h2>
						<p
							class="opacity-80 text-[#E4EAF0] text-xl hidden md:block max-w-lg"
						>
							Stop living on autopilot and start experiencing
							every moment with Life Visor by Devsign — your guide
							to a more mindful day.
						</p>
						<!-- Desktop badges -->
						<div
							class="hidden md:flex gap-4 items-end mt-15 flex-wrap"
						>
							<a
								id="badge-appstore-desktop"
								href={APP_STORE_URL}
								target="_blank"
								rel="noopener noreferrer"
								class="transition-opacity hover:opacity-80"
							>
								<img
									src={badgeAppStore}
									height="46"
									style="height:58px;width:auto;display:block;"
									alt="Download on the App Store"
								/>
							</a>
							<a
								id="badge-playstore-desktop"
								href={PLAY_STORE_URL}
								target="_blank"
								rel="noopener noreferrer"
								class="transition-opacity hover:opacity-80"
							>
								<img
									src={badgePlayStore}
									height="46"
									style="height:58px;width:auto;display:block;"
									alt="Get it on Google Play"
								/>
							</a>
						</div>
					</div>

					<Image
						src={hero1}
						class="fade-in-section lg:pr-16 md:pr-4 self-start md:w-90 lg:w-120"
						layout="constrained"
						width={1242}
						height={1326}
						alt="Smartphone running the Life Visor app, showing the main screen."
					/>

					<!-- Mobile badges -->
					<div
						class="flex gap-3 items-end justify-center mx-auto md:hidden mt-15 flex-wrap"
					>
						<a
							id="badge-appstore-mobile"
							href={APP_STORE_URL}
							target="_blank"
							rel="noopener noreferrer"
							class="transition-opacity hover:opacity-80"
						>
							<img
								src={badgeAppStore}
								height="40"
								style="height:50px;width:auto;display:block;"
								alt="Download on the App Store"
							/>
						</a>
						<a
							id="badge-playstore-mobile"
							href={PLAY_STORE_URL}
							target="_blank"
							rel="noopener noreferrer"
							class="transition-opacity hover:opacity-80"
						>
							<img
								src={badgePlayStore}
								height="40"
								style="height:50px;width:auto;display:block;"
								alt="Get it on Google Play"
							/>
						</a>
					</div>
				</div>

				<div class="md:hidden">
					<p
						class="opacity-80 text-[#E4EAF0] text-center px-12 text-xl py-10"
					>
						Stop living on autopilot and start experiencing every
						moment with Life Visor — your guide to a more mindful
						day.
					</p>
				</div>
			</div>
		</section>
	</main>
</div>

<style>
	.glass {
		backdrop-filter: blur(10px);
	}
</style>

<script>
	(function () {
		const ua = navigator.userAgent;
		const isIOS = /iPhone|iPad|iPod/i.test(ua);
		const isAndroid = /Android/i.test(ua);

		if (isIOS) {
			// Hide Play Store badges
			document
				.getElementById("badge-playstore-desktop")
				?.style.setProperty("display", "none");
			document
				.getElementById("badge-playstore-mobile")
				?.style.setProperty("display", "none");
		} else if (isAndroid) {
			// Hide App Store badges
			document
				.getElementById("badge-appstore-desktop")
				?.style.setProperty("display", "none");
			document
				.getElementById("badge-appstore-mobile")
				?.style.setProperty("display", "none");
		}
		// Desktop: show both (default)
	})();
</script>
