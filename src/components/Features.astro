---
const features = [
  {
    title: "Custom activities",
    description: "Track what matters to you. Pick a name, color, and category — done.",
    icon: `<rect x="3" y="3" width="7" height="7" rx="1.5"/><rect x="14" y="3" width="7" height="7" rx="1.5"/><rect x="3" y="14" width="7" height="7" rx="1.5"/><rect x="14" y="14" width="7" height="7" rx="1.5"/>`,
  },
  {
    title: "Sessions in seconds",
    description: "One tap to start, one tap to stop. Live indicator while it runs.",
    icon: `<circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>`,
  },
  {
    title: "Daily summary",
    description: "See exactly where your day went, with totals and breakdowns.",
    icon: `<rect x="3" y="3" width="18" height="18" rx="2"/><line x1="3" y1="9" x2="21" y2="9"/><line x1="9" y1="21" x2="9" y2="9"/>`,
  },
  {
    title: "Intuitive charts",
    description: "Visualize your habits over hours, days, and weeks at a glance.",
    icon: `<line x1="3" y1="20" x2="21" y2="20"/><rect x="6" y="11" width="3" height="9" rx="0.5"/><rect x="11" y="6" width="3" height="14" rx="0.5"/><rect x="16" y="14" width="3" height="6" rx="0.5"/>`,
  },
  {
    title: "Pattern discovery",
    description: "Spot the small habits that quietly shape your weeks.",
    icon: `<path d="M3 12h4l3-9 4 18 3-9h4"/>`,
  },
  {
    title: "Local-only by design",
    description: "Your data never leaves your device. No accounts, no tracking, no servers.",
    icon: `<rect x="4" y="11" width="16" height="10" rx="2"/><path d="M8 11V7a4 4 0 0 1 8 0v4"/>`,
  },
];
---

<section id="features" class="w-full px-5 sm:px-8 py-20 sm:py-28">
  <div class="max-w-6xl mx-auto fade-in">
    <div class="flex items-center gap-3 mb-8">
      <span class="block w-5 h-[2px] bg-muted-2"></span>
      <span class="eyebrow text-ink-soft">WHAT YOU CAN DO</span>
    </div>

    <h2 class="text-4xl sm:text-5xl font-bold text-ink leading-[1.1] tracking-tight mb-12 sm:mb-16 max-w-3xl">
      Simple tools to understand <span class="highlight-orange">your time</span>
    </h2>

    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5 lg:gap-6">
      {features.map((f) => (
        <div class="bg-bg-card border border-line-soft rounded-3xl p-7">
          <div class="w-11 h-11 rounded-xl bg-bg-soft flex items-center justify-center mb-5">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#3D4046" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" set:html={f.icon} />
          </div>
          <h3 class="text-base font-semibold text-ink mb-2">{f.title}</h3>
          <p class="text-sm text-muted leading-relaxed">{f.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
